# Flask Secret Key (Change this to a strong random string)
SECRET_KEY=quantum-secure-key-2024-iot-networks

# Application Base URL (Important for QR codes to work when scanned from phones)
# For development on local network, use your computer's local IP address
# Example: APP_BASE_URL=http://192.168.1.100:5000
# For production, use your actual domain
# Example: APP_BASE_URL=https://yourdomain.com
APP_BASE_URL=http://192.168.0.108:5000

# ==================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==================================================
# To use Gmail:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password below (not your regular Gmail password)

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=test@gmail.com
MAIL_PASSWORD=fhrldyroqqebkvtu
MAIL_DEFAULT_SENDER=test@gmail.com

